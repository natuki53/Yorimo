NODE_ENV=production
PORT=4000

POSTGRES_DB=yorimo
POSTGRES_USER=yorimo
POSTGRES_PASSWORD=replace-with-64-hex-characters

JWT_SECRET=replace-with-at-least-128-hex-characters
JWT_EXPIRES_IN=8h
DEMO_MODE=true
ALLOW_DEMO_RESET=false
EXPOSE_API_DOCS=false
CORS_ORIGINS=https://yorimo.mu-natuki.com

DEMO_LOGIN_RATE_LIMIT=90
DEMO_MUTATION_RATE_LIMIT=600
RECOMMENDATION_RATE_LIMIT=180

# Runtime server key. Restrict this key to Places API (New).
GOOGLE_MAPS_SERVER_API_KEY=replace-with-server-key
# Build-time browser key. Restrict this key to Maps JavaScript API and
# https://yorimo.mu-natuki.com/*.
VITE_GOOGLE_MAPS_API_KEY=replace-with-browser-key
